name: "lowrisc:dv:axi_agent:0.1"
description: "AXI agent"
filesets:
  files_dv:
    files:
      - axi_read_data_if.sv
      - axi_read_request_if.sv
      - axi_write_data_if.sv
      - axi_write_request_if.sv
      - axi_write_response_if.sv
    file_type: systemVerilogSource

targets:
  default:
    filesets:
      - files_dv
